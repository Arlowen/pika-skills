<idea-plugin>
  <id>com.pika.ideaControlMcp</id>
  <name>Run and Changelist Control MCP</name>
  <vendor>Pika</vendor>

  <description><![CDATA[
    Adds deterministic Run/Debug service control and IDE changelist operations to the
    JetBrains MCP Server plugin.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.vcs</depends>
  <depends>com.intellij.mcpServer</depends>

  <extensions defaultExtensionNs="com.intellij">
    <projectService serviceImplementation="com.pika.idea.mcp.ExecutionRegistry"/>
    <postStartupActivity implementation="com.pika.idea.mcp.ExecutionRegistryStartupActivity"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.mcpServer">
    <mcpTool implementation="com.pika.idea.mcp.tools.IdeaListServicesTool"/>
    <mcpTool implementation="com.pika.idea.mcp.tools.IdeaStartServiceTool"/>
    <mcpTool implementation="com.pika.idea.mcp.tools.IdeaStopServiceTool"/>
    <mcpTool implementation="com.pika.idea.mcp.tools.IdeaListChangelistsTool"/>
    <mcpTool implementation="com.pika.idea.mcp.tools.IdeaMoveChangesToChangelistTool"/>
  </extensions>
</idea-plugin>
