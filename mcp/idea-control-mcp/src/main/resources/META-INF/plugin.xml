<idea-plugin>
  <id>com.pika.ideaControlMcp</id>
  <name>Pika MCP</name>
  <vendor>Pika</vendor>

  <description><![CDATA[
    Exposes deterministic Run/Debug service control and IDE changelist operations through an
    independent local Model Context Protocol server.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.vcs</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.pika.idea.mcp.PikaMcpServerService"/>
    <projectService serviceImplementation="com.pika.idea.mcp.ExecutionRegistry"/>
    <postStartupActivity implementation="com.pika.idea.mcp.ExecutionRegistryStartupActivity"/>
  </extensions>
</idea-plugin>
